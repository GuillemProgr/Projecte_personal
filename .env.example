# ─── Base de datos ─────────────────────────────────────────────────
# PostgreSQL (Neon, Supabase, Railway…)
# Crea una base de datos gratuita en https://neon.tech o https://supabase.com
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
# Supabase necesita DIRECT_URL para migraciones Prisma
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── NextAuth ──────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Genera un secreto: openssl rand -base64 32
NEXTAUTH_SECRET="cambia-esto-por-un-secreto-seguro-de-al-menos-32-caracteres"

# ─── Google OAuth (opcional pero recomendado) ──────────────────────
# Crea credenciales en https://console.cloud.google.com/apis/credentials
# URI de redirección: https://tu-dominio.com/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Anthropic Claude ──────────────────────────────────────────────
# Obtén tu key en https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-api03-..."

# ─── Stripe (próximamente) ─────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
